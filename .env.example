# ============================================
# TRAD SNIPER BOT - Environment Configuration
# ============================================

# ---- Language Setting ----
# Options: "en" | "ar"
LANGUAGE=en

# ---- Mode ----
# Options: "live" | "paper"
TRADING_MODE=paper

# ---- Solana Configuration ----
