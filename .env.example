SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
SOLANA_GRPC_URL=your-geyser-grpc-endpoint:443
SOLANA_GRPC_TOKEN=your-grpc-auth-token
SOLANA_PRIVATE_KEY=your-base58-private-key
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_TIP_ACCOUNT=96gYZGLnJYVFmbjzopPSU6QiEV5fGqZNyN9nmNhvrZU5
JITO_DEFAULT_TIP_LAMPORTS=10000

# ---- Base (EVM L2) Configuration ----
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_PRIVATE_KEY=0xyour-private-key
BASE_FLASHBOTS_RPC=https://rpc.flashbots.net
BASE_MAX_PRIORITY_FEE_GWEI=50

# ---- Sui Configuration ----
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_WS_URL=wss://fullnode.mainnet.sui.io
