# ---- Risk Management ----
MAX_BUY_AMOUNT_SOL=0.5
MAX_BUY_AMOUNT_ETH=0.1
MAX_BUY_AMOUNT_SUI=50
TRAILING_STOP_PERCENT=20
TAKE_PROFIT_PERCENT=100
MAX_SLIPPAGE_PERCENT=15
MAX_GAS_LIMIT_GWEI=100

# ---- Security Thresholds ----
